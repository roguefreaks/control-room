# ── Site ────────────────────────────────────────────────────────────────
# Canonical URL (used for metadata, sitemap, JSON-LD). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# ── Supabase (visitor telemetry + signal board) ─────────────────────────
# Create a project → run supabase/schema.sql in the SQL editor → paste keys.
# Both optional: without them the site still works, telemetry/signals hide.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── GitHub deploy feed ──────────────────────────────────────────────────
# Optional. A fine-grained token for the SKY830-sudo account (read-only,
# no repo contents needed) lets the feed include private freelance activity.
# Without it, only public events from both accounts are shown.
GITHUB_TOKEN=

# ── Moderation + privacy ────────────────────────────────────────────────
# Random secret for the guestbook admin DELETE route (x-admin-token header).
ADMIN_TOKEN=
# Salt for one-way IP hashing in rate limiting. Any random string.
TELEMETRY_SALT=
